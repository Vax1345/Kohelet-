rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: chapters
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - content: string (required, 1-5000 chars)
    //   - originalThought: string (optional, 1-5000 chars)
    //   - authorId: string (required, matches auth.uid)
    //   - authorName: string (required, 1-100 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "TZACHI@vax-man.com" && request.auth.token.email_verified == true));
    }

    function isValidChapter(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidRating(data) {
      return data.keys().hasAll(['chapterId', 'userId', 'score', 'createdAt']) &&
             data.chapterId is string &&
             data.userId == request.auth.uid &&
             data.score is number && data.score >= 1 && data.score <= 5 &&
             data.createdAt is timestamp;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['chapterId', 'authorId', 'authorName', 'content', 'createdAt']) &&
             data.chapterId is string &&
             data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    match /chapters/{chapterId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidChapter(request.resource.data);
      allow update: if (isOwner(resource.data.authorId) && isValidChapter(request.resource.data)) ||
                    (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingCount', 'ratingSum'])) ||
                    isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidRating(request.resource.data) && ratingId == request.auth.uid + "_" + request.resource.data.chapterId;
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidRating(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId) || isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update: if (isOwner(resource.data.authorId) && isValidComment(request.resource.data)) ||
                    (isAuthenticated() && isOwner(get(/databases/$(database)/documents/chapters/$(resource.data.chapterId)).data.authorId)) ||
                    isAdmin();
      allow delete: if isOwner(resource.data.authorId) || 
                    (isAuthenticated() && isOwner(get(/databases/$(database)/documents/chapters/$(resource.data.chapterId)).data.authorId)) ||
                    isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }
  }
}
